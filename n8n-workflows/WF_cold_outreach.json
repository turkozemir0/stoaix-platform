    {
      "id": "n13",
      "name": "Prepare Touch 1 Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2820,
        60
      ],
      "parameters": {
        "jsCode": "const lead = $('Pick Eligible Lead').first().json;\nconst templates = $input.all().map(i => i.json);\n\nif (!templates.length) {\n  return [{ json: { skip: true, leadId: lead.leadId } }];\n}\n\nconst tpl = templates[0];\nconst firstName = (lead.name || '').split(' ')[0] || 'Hallo';\n\nconst message = tpl.message\n  .replace(/\\{\\{name\\}\\}/g, firstName)\n  .replace(/\\{\\{agent_name\\}\\}/g, lead.agentName || 'Asistan');\n\nreturn [{ json: {\n  ...lead,\n  message,\n  skip: false\n}}];"
      }
    },
