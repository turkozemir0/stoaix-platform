              "value": "=Bearer {{ $('Config').first().json.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "eq.active"
            },
            {
              "name": "select",
              "value": "id,name,crm_config,ai_persona,timezone,excluded_phones"
            },
            {
              "name": "crm_config->>provider",
              "value": "eq.ghl"
            }
