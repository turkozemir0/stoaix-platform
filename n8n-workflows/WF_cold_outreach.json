      "parameters": {
        "jsCode": "const res = $input.first().json;\nconst lead = $('Prepare Touch 1 Message').first().json;\nconst contacts = res.contacts || [];\nconst ghlContact = contacts[0];\n\nif (!ghlContact) {\n  return [{ json: { ghlContactId: null, leadId: lead.leadId } }];\n}\n\nreturn [{ json: { ...lead, ghlContactId: ghlContact.id } }];"
      }
