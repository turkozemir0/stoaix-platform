    {
      "id": "n03",
      "name": "Check Business Hours (Org TZ)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        300
      ],
      "parameters": {
        "jsCode": "const org = $input.first().json;\nconst now = new Date();\nconst timezone = org.orgTimezone || 'Europe/Berlin';\nconst localTime = new Date(now.toLocaleString('en-US', { timeZone: timezone }));\nconst hour = localTime.getHours();\nconst day = localTime.getDay(); // 0=Sun, 6=Sat\n\nconst hourStart = org.HOUR_START;\nconst hourEnd = org.HOUR_END;\n\nif (day === 0 || day === 6 || hour < hourStart || hour >= hourEnd) {\n  return [{ json: { ...org, allowed: false, reason: `Outside business hours (${timezone} ${hour}:xx, day ${day})` } }];\n}\n\nreturn [{ json: { ...org, allowed: true } }];"
      }
    },
    {
      "id": "n04",
      "name": "Is Org Business Hours?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1500,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.allowed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "n05",
      "name": "Get Active GHL Orgs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
