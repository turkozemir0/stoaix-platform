    {
      "id": "n31",
      "name": "GHL Send Touch 2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3680,
        380
      ],
      "parameters": {
        "jsCode": "const task = $('Enrich Task with Org Config').first().json;\nconst tplArr = $input.all().map(i => i.json);\nif (!tplArr.length) return [{ json: { skipped: true } }];\n\nconst tpl = tplArr[0];\nconst firstName = (task.name || '').split(' ')[0] || 'Hallo';\nconst message = tpl.message\n  .replace(/\\{\\{name\\}\\}/g, firstName)\n  .replace(/\\{\\{agent_name\\}\\}/g, task.agentName || 'Asistan');\n\nawait fetch('https://services.leadconnectorhq.com/conversations/messages', {\n  method: 'POST',\n  headers: {\n    'Authorization': `Bearer ${task.pitToken}`,\n    'Version': '2021-04-15',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({ type: 'SMS', contactId: task.ghlContactId, message })\n});\n\nawait fetch(`${task.SUPABASE_URL}/rest/v1/follow_up_tasks?id=eq.${task.taskId}`, {\n  method: 'PATCH',\n  headers: {\n    'apikey': task.SUPABASE_SERVICE_KEY,\n    'Authorization': `Bearer ${task.SUPABASE_SERVICE_KEY}`,\n    'Content-Type': 'application/json',\n    'Prefer': 'return=minimal'\n  },\n  body: JSON.stringify({ status: 'sent' })\n});\n\nreturn [{ json: { sent: true, taskId: task.taskId, leadId: task.leadId } }];"
      }
    },
    {
      "id": "n32",
      "name": "Mark Lead Lost",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3460,
        540
      ],
      "parameters": {
        "jsCode": "const task = $('Enrich Task with Org Config').first().json;\n\n// Mark lead as lost\nawait fetch(`${task.SUPABASE_URL}/rest/v1/leads?id=eq.${task.leadId}`, {\n  method: 'PATCH',\n  headers: {\n    'apikey': task.SUPABASE_SERVICE_KEY,\n    'Authorization': `Bearer ${task.SUPABASE_SERVICE_KEY}`,\n    'Content-Type': 'application/json',\n    'Prefer': 'return=minimal'\n  },\n  body: JSON.stringify({ status: 'lost' })\n});\n\n// Cancel all remaining cold tasks for this lead\nawait fetch(`${task.SUPABASE_URL}/rest/v1/follow_up_tasks?lead_id=eq.${task.leadId}&task_type=eq.cold_outreach&status=eq.pending`, {\n  method: 'PATCH',\n  headers: {\n    'apikey': task.SUPABASE_SERVICE_KEY,\n    'Authorization': `Bearer ${task.SUPABASE_SERVICE_KEY}`,\n    'Content-Type': 'application/json',\n    'Prefer': 'return=minimal'\n  },\n  body: JSON.stringify({ status: 'cancelled' })\n});\n\nreturn [{ json: { markedLost: true, leadId: task.leadId } }];"
      }
    }
