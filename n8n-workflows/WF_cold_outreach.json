        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "n07",
      "name": "Extract Org Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "jsCode": "const org = $input.first().json;\nconst crm = typeof org.crm_config === 'string' ? JSON.parse(org.crm_config) : org.crm_config;\nconst persona = typeof org.ai_persona === 'string' ? JSON.parse(org.ai_persona) : (org.ai_persona || {});\nconst excludedPhones = Array.isArray(org.excluded_phones) ? org.excluded_phones : [];\nreturn [{ json: {\n  orgId:      org.id,\n  orgName:    org.name,\n  orgTimezone: org.timezone || 'Europe/Berlin',\n  agentName:  persona.persona_name || 'Asistan',\n  locationId: crm.location_id,\n  pitToken:   crm.pit_token,\n  excludedPhones,\n  SUPABASE_URL: $('Config').first().json.SUPABASE_URL,\n  SUPABASE_SERVICE_KEY: $('Config').first().json.SUPABASE_SERVICE_KEY,\n  HOUR_START: $('Config').first().json.HOUR_START,\n  HOUR_END: $('Config').first().json.HOUR_END,\n  TOUCH2_DELAY_DAYS:   $('Config').first().json.TOUCH2_DELAY_DAYS,\n  CLEANUP_DELAY_DAYS:  $('Config').first().json.CLEANUP_DELAY_DAYS\n}}];"
      }
    },
    {
      "id": "n08",
      "name": "═══ PHASE 1: New Outreach ═══",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1720,
        100
      ]
    },
    {
      "id": "n09",
      "name": "Get Candidate Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1940,
        100
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $('Extract Org Config').first().json.SUPABASE_URL }}/rest/v1/leads",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $('Extract Org Config').first().json.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Extract Org Config').first().json.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "organization_id",
              "value": "=eq.{{ $('Extract Org Config').first().json.orgId }}"
            },
            {
              "name": "status",
              "value": "eq.new"
            },
            {
              "name": "source_channel",
              "value": "eq.import"
            },
            {
              "name": "select",
              "value": "id,contact_id,collected_data,contacts(phone,full_name)"
            },
            {
              "name": "order",
              "value": "created_at.asc"
            },
            {
              "name": "limit",
              "value": "15"
            }
          ]
        }
      }
    },
    {
      "id": "n10",
      "name": "Pick Eligible Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        100
      ],
      "parameters": {
        "jsCode": "// Filter out leads that already have cold outreach started\nconst leads = $input.all().map(i => i.json);\nconst orgConfig = $('Extract Org Config').first().json;\nconst normalizePhone = (raw) => String(raw || '').replace(/\\D/g, '');\nconst excludedPhones = new Set((orgConfig.excludedPhones || []).map(normalizePhone).filter(Boolean));\n\nfor (const lead of leads) {\n  // Skip if cold_outreach_started already set\n  const data = typeof lead.collected_data === 'string' ? JSON.parse(lead.collected_data) : (lead.collected_data || {});\n  if (data.cold_outreach_started) continue;\n\n  // Skip if no phone\n  const phone = lead.contacts?.phone;\n  if (!phone) continue;\n\n  if (excludedPhones.has(normalizePhone(phone))) continue;\n\n  return [{ json: {\n    leadId:    lead.id,\n    contactId: lead.contact_id,\n    phone:     phone,\n    name:      lead.contacts?.full_name || '',\n    orgId:     orgConfig.orgId,\n    orgName:   orgConfig.orgName,\n    agentName: orgConfig.agentName,\n    locationId: orgConfig.locationId,\n    pitToken:  orgConfig.pitToken,\n    excludedPhones: orgConfig.excludedPhones,\n    SUPABASE_URL: orgConfig.SUPABASE_URL,\n    SUPABASE_SERVICE_KEY: orgConfig.SUPABASE_SERVICE_KEY,\n    TOUCH2_DELAY_DAYS:   orgConfig.TOUCH2_DELAY_DAYS,\n    CLEANUP_DELAY_DAYS:  orgConfig.CLEANUP_DELAY_DAYS\n  }}];\n}\n\n// No eligible lead found\nreturn [{ json: { leadId: null } }];"
      }
    },
