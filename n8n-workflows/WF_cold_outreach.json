      ],
      "parameters": {
        "jsCode": "const task = $input.first().json;\nconst org = $('Extract Org Config').first().json;\nconst vars = typeof task.variables === 'string' ? JSON.parse(task.variables) : (task.variables || {});\nreturn [{ json: {\n  taskId:        task.id,\n  leadId:        task.lead_id,\n  contactId:     task.contact_id,\n  templateKey:   task.template_key,\n  ghlContactId:  vars.ghl_contact_id || null,\n  phone:         vars.phone || null,\n  name:          vars.name || '',\n  agentName:     vars.agent_name || 'Asistan',\n  orgId:         org.orgId,\n  locationId:    org.locationId,\n  pitToken:      org.pitToken,\n  excludedPhones: org.excludedPhones || [],\n  SUPABASE_URL:  org.SUPABASE_URL,\n  SUPABASE_SERVICE_KEY: org.SUPABASE_SERVICE_KEY\n}}];"
      }
    },
    {
      "id": "n26",
      "name": "Check Conversations / Excluded",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2800,
        380
      ],
      "parameters": {
        "jsCode": "const task = $('Enrich Task with Org Config').first().json;\nconst normalizePhone = (raw) => String(raw || '').replace(/\\D/g, '');\nconst excludedPhones = new Set((task.excludedPhones || []).map(normalizePhone).filter(Boolean));\nconst normalizedPhone = normalizePhone(task.phone);\nconst isExcludedPhone = normalizedPhone ? excludedPhones.has(normalizedPhone) : false;\n\nif (isExcludedPhone) {\n  return [{ json: { ...task, stopSequence: true, stopReason: 'excluded_phone' } }];\n}\n\nconst url = `${task.SUPABASE_URL}/rest/v1/conversations?organization_id=eq.${task.orgId}&contact_id=eq.${task.contactId}&select=id&limit=1`;\nconst res = await fetch(url, {\n  method: 'GET',\n  headers: {\n    apikey: task.SUPABASE_SERVICE_KEY,\n    Authorization: `Bearer ${task.SUPABASE_SERVICE_KEY}`,\n  },\n});\n\nconst conversations = await res.json();\nconst hasConversation = Array.isArray(conversations) && conversations.length > 0;\n\nreturn [{ json: { ...task, stopSequence: hasConversation, stopReason: hasConversation ? 'existing_conversation' : null } } }];"
      }
    },
